---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Strategio — Consultoría Estratégica de Alto Nivel',
  description = 'Asesoramos a organizaciones que buscan claridad, estructura y dirección. Finanzas corporativas, planeamiento estratégico y modelos de gestión para empresas que aspiran a más.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://strategio.pe" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <style>
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      @keyframes lineExpand {
        from { width: 0; }
        to   { width: 3rem; }
      }
      .animate-fade-in-up { animation: fadeInUp 0.8s ease both; }
      .animate-fade-in    { animation: fadeIn 1.2s ease both; }
      .animate-line       { animation: lineExpand 1s ease both; }
      .delay-100  { animation-delay: 0.1s; }
      .delay-200  { animation-delay: 0.2s; }
      .delay-300  { animation-delay: 0.3s; }
      .delay-500  { animation-delay: 0.5s; }
      .delay-700  { animation-delay: 0.7s; }

      .gold-divider {
        display: block;
        width: 3rem;
        height: 1px;
        background: #c9a84c;
        margin: 1.5rem 0;
      }

      .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 60px rgba(201, 168, 76, 0.08);
      }

      .nav-link {
        position: relative;
        letter-spacing: 0.12em;
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        color: #a8a09b;
        transition: color 0.3s ease;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: #c9a84c;
        transition: width 0.3s ease;
      }
      .nav-link:hover { color: #f5f0e8; }
      .nav-link:hover::after { width: 100%; }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 2rem;
        background: #c9a84c;
        color: #0a0a0a;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        transition: background 0.3s ease, transform 0.2s ease;
      }
      .btn-primary:hover {
        background: #e8c97a;
        transform: translateX(2px);
      }

      .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 2rem;
        border: 1px solid #c9a84c;
        color: #c9a84c;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        transition: background 0.3s ease, color 0.3s ease;
      }
      .btn-outline:hover {
        background: #c9a84c;
        color: #0a0a0a;
      }

      .stat-number {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 300;
        color: #c9a84c;
        line-height: 1;
      }

      .section-label {
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #c9a84c;
        font-weight: 500;
      }

      .hero-title {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(3rem, 7vw, 6.5rem);
        font-weight: 300;
        line-height: 1.05;
        letter-spacing: -0.01em;
        color: #f5f0e8;
      }

      .hero-title em {
        font-style: italic;
        color: #c9a84c;
      }

      .section-title {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 300;
        line-height: 1.15;
        color: #f5f0e8;
      }

      .card-service {
        border: 1px solid #2e2e2e;
        background: #141414;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s ease;
      }
      .card-service::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 2px;
        background: linear-gradient(90deg, #c9a84c, transparent);
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .card-service:hover { border-color: #8a6f2e; }
      .card-service:hover::before { opacity: 1; }

      .testimonial-card {
        border-left: 1px solid #c9a84c;
        padding: 2rem 2rem 2rem 2.5rem;
        background: #141414;
      }

      .number-accent {
        font-family: "Cormorant Garamond", Georgia, serif;
        font-size: 5rem;
        font-weight: 300;
        color: #1e1e1e;
        line-height: 1;
        position: absolute;
        top: -1rem;
        right: 1.5rem;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
