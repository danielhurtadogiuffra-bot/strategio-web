      <!-- Servicios -->
      <div>
        <p class="section-label mb-6">Servicios</p>
        <ul class="flex flex-col gap-3">
          <li><a href="#servicios" class="text-sm text-mist hover:text-gold transition-colors" style="color:#a8a09b;">Finanzas Corporativas</a></li>
