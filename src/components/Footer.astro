---
---
<footer style="background:#0A0A19; border-top:1px solid #2A2740;">
  <div class="max-w-7xl mx-auto px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 group mb-4">
          <svg width="32" height="32" viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg" fill="white">
            <polygon points="5,5 29,5 5,29"/>
            <rect x="33" y="5" width="24" height="24"/>
            <polygon points="61,5 85,5 85,29"/>
            <polygon points="5,33 5,57 29,45"/>
            <polygon points="85,33 85,57 61,45"/>
            <polygon points="5,61 5,85 29,85"/>
            <rect x="33" y="61" width="24" height="24"/>
            <polygon points="61,85 85,85 85,61"/>
          </svg>
          <span style="font-family:'Archivo',sans-serif; font-weight:900; font-size:1.1rem; color:#F8F8FF; letter-spacing:-0.01em;">
            Strategi<span style="color:#4D0FC1;">o</span>
          </span>
        </a>
        <span class="purple-line mt-2 mb-4"></span>
        <p class="text-sm leading-relaxed max-w-xs" style="color:#9B97AA;">
          Asesoramos a organizaciones que buscan claridad, estructura y dirección en sus finanzas y estrategia corporativa.
        </p>
        <div class="flex gap-4 mt-6">
          <a href="https://linkedin.com" target="_blank" rel="noopener"
            class="w-9 h-9 flex items-center justify-center transition-colors"
            style="border:1px solid #2A2740; color:#9B97AA;"
            aria-label="LinkedIn"
            onmouseover="this.style.borderColor='#4D0FC1';this.style.color='#4D0FC1';"
            onmouseout="this.style.borderColor='#2A2740';this.style.color='#9B97AA';">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Servicios -->
      <div>
        <p class="section-label mb-6">Servicios</p>
        <ul class="flex flex-col gap-3">
          <li><a href="/#servicios" class="text-sm transition-colors" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">Finanzas Corporativas</a></li>
          <li><a href="/#servicios" class="text-sm transition-colors" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">Planeamiento Estratégico</a></li>
          <li><a href="/#servicios" class="text-sm transition-colors" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">Modelos de Gestión</a></li>
          <li><a href="/#servicios" class="text-sm transition-colors" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">Reestructuración Financiera</a></li>
          <li><a href="/#servicios" class="text-sm transition-colors" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">Due Diligence</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <p class="section-label mb-6">Contacto</p>
        <ul class="flex flex-col gap-4">
          <li class="flex gap-3 text-sm" style="color:#9B97AA;">
            <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D0FC1" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span>Av. Del Pinar 180, Of. 1201<br/>Chacarilla, Santiago de Surco<br/>Lima, Perú</span>
          </li>
          <li class="flex gap-3 text-sm" style="color:#9B97AA;">
            <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D0FC1" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+51961598048" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">+51 961 598 048</a>
          </li>
          <li class="flex gap-3 text-sm" style="color:#9B97AA;">
            <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4D0FC1" stroke-width="1.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:administracion@strategio.pe" style="color:#9B97AA;" onmouseover="this.style.color='#4D0FC1';" onmouseout="this.style.color='#9B97AA';">administracion@strategio.pe</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-top:1px solid #2A2740;">
      <p class="text-xs" style="color:#9B97AA; letter-spacing:0.05em;">
        © 2025 Strategio. Todos los derechos reservados.
      </p>
      <p class="text-xs" style="color:#4D0FC1; letter-spacing:0.08em;">
        Consultoría Estratégica · Lima, Perú
      </p>
    </div>
  </div>
</footer>
