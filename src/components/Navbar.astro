---
const links = [
  { href: '/#diagnostico', label: '¿Quiénes somos?' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#porque', label: '¿Por qué Strategio?' },
  { href: '/#manifiesto', label: 'Manifiesto' },
];
---

<nav id="navbar">
  <a href="/" class="logo">
    <svg class="logo-icon" width="32" height="32" viewBox="0 0 116 116" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M 14.0,38.0 Q 10,38 12.8,35.2 L 35.2,12.8 Q 38,10 38.0,14.0 L 38.0,34.0 Q 38,38 34.0,38.0 Z" fill="#6B35E8"/>
      <rect x="44" y="10" width="28" height="28" rx="3.5" fill="#6B35E8"/>
      <path d="M 78.0,14.0 Q 78,10 80.8,12.8 L 103.2,35.2 Q 106,38 102.0,38.0 L 82.0,38.0 Q 78,38 78.0,34.0 Z" fill="#6B35E8"/>
      <path d="M 12.8,46.8 Q 10,44 14.0,44.0 L 34.0,44.0 Q 38,44 38.0,48.0 L 38.0,68.0 Q 38,72 35.2,69.2 Z" fill="#6B35E8"/>
      <path d="M 78.0,48.0 Q 78,44 80.8,46.8 L 103.2,69.2 Q 106,72 102.0,72.0 L 82.0,72.0 Q 78,72 78.0,68.0 Z" fill="#6B35E8"/>
      <path d="M 12.8,80.8 Q 10,78 14.0,78.0 L 34.0,78.0 Q 38,78 38.0,82.0 L 38.0,102.0 Q 38,106 35.2,103.2 Z" fill="#6B35E8"/>
      <rect x="44" y="78" width="28" height="28" rx="3.5" fill="#6B35E8"/>
      <path d="M 78.0,82.0 Q 78,78 82.0,78.0 L 102.0,78.0 Q 106,78 103.2,80.8 L 80.8,103.2 Q 78,106 78.0,102.0 Z" fill="#6B35E8"/>
    </svg>
    Strategio
  </a>
  <ul>
    {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    <li><a href="/#contacto" class="nav-cta">Empieza aquí →</a></li>
  </ul>
  <button class="nav-hamburger" id="menuBtn" aria-label="Abrir menú">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul>
    {links.map((l) => <li><a href={l.href} class="mobile-link">{l.label}</a></li>)}
    <li><a href="/#contacto" class="mobile-link mobile-menu-cta">Empieza aquí →</a></li>
  </ul>
  <span class="mobile-menu-footer">Strategio · Lima, Perú</span>
</div>

<style>
  nav {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    background: rgba(13, 12, 20, 0.88);
    border: 1px solid var(--border);
    border-radius: 100px;
    backdrop-filter: blur(20px);
    width: calc(100% - 80px);
    max-width: 1200px;
    transition: background 0.3s, border-color 0.3s;
  }
  nav.scrolled {
    background: rgba(13, 12, 20, 0.97);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 17px;
    color: var(--white);
    text-decoration: none;
  }
  .logo-icon { width: 26px; height: 26px; }
  nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 28px;
  }
  nav ul a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }
  nav ul a:hover { color: var(--white); }
  .nav-cta {
    background: var(--white) !important;
    color: var(--black) !important;
    padding: 10px 22px;
    border-radius: 100px;
    font-size: 13px !important;
    font-weight: 700 !important;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--lavender) !important; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 6px;
    background: none;
    border: none;
    z-index: 200;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
    transform-origin: center;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(13, 12, 20, 0.97);
    backdrop-filter: blur(24px);
    z-index: 150;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .mobile-menu.open { opacity: 1; pointer-events: auto; }
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 0 32px;
  }
  .mobile-menu ul li { width: 100%; text-align: center; }
  .mobile-menu ul a {
    display: block;
    font-size: 24px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    padding: 18px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s;
    letter-spacing: -0.02em;
  }
  .mobile-menu ul a:hover { color: var(--white); }
  .mobile-menu-cta {
    margin-top: 32px;
    background: var(--purple);
    color: var(--white) !important;
    padding: 16px 40px !important;
    border-radius: 100px !important;
    font-size: 16px !important;
    border-bottom: none !important;
    display: inline-block !important;
  }
  .mobile-menu-footer {
    position: absolute;
    bottom: 48px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    nav { top: 12px; width: calc(100% - 32px); padding: 12px 20px; }
    nav ul { display: none; }
    .nav-hamburger { display: flex; }
    .mobile-menu { display: flex; }
  }
  @media (max-width: 480px) {
    nav { width: calc(100% - 24px); }
  }
</style>

<script>
  const btn = document.getElementById('menuBtn');
  const menu = document.getElementById('mobileMenu');
  const nav = document.getElementById('navbar');
  const mlinks = document.querySelectorAll('.mobile-link');

  btn?.addEventListener('click', () => {
    btn.classList.toggle('open');
    menu?.classList.toggle('open');
    document.body.style.overflow = menu?.classList.contains('open') ? 'hidden' : '';
  });
  mlinks.forEach((l) =>
    l.addEventListener('click', () => {
      btn?.classList.remove('open');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    })
  );
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) nav?.classList.add('scrolled');
    else nav?.classList.remove('scrolled');
  });
</script>
