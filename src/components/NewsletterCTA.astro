---
interface Props {
  variant?: 'full' | 'inline';
}
const { variant = 'full' } = Astro.props;
---

<div class={`news-cta ${variant === 'inline' ? 'news-cta-inline' : ''}`}>
  <div class="news-cta-inner">
    <span class="badge-white"><span class="badge-white-dot"></span>Newsletter</span>
    <h3 class="news-cta-title">
      Ideas claras sobre <span class="news-accent">orden y crecimiento</span>.
    </h3>
    <p class="news-cta-desc">
      Análisis de alto nivel sobre finanzas, estrategia y gestión. Sin ruido, directo a tu bandeja.
    </p>
    <form class="news-form" id="newsForm">
      <input
        type="email"
        name="email"
        class="news-input"
        placeholder="tu@correo.com"
        required
      />
      <button type="submit" class="btn-primary news-btn">Suscribirme →</button>
    </form>
    <p class="news-note" id="newsMsg"></p>
  </div>
</div>

<style>
  .news-cta {
    background: rgba(107, 53, 232, 0.07);
    border: 1px solid rgba(107, 53, 232, 0.2);
    border-radius: 24px;
    padding: 48px 44px;
    position: relative;
    overflow: hidden;
  }
  .news-cta::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light), transparent);
  }
  .news-cta-inline { padding: 36px 32px; border-radius: 16px; }
  .news-cta-inner { max-width: 540px; }
  .news-cta-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 18px 0 12px;
  }
  .news-accent { color: var(--purple-light); }
  .news-cta-desc {
    font-size: 15px;
    line-height: 1.7;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 24px;
  }
  .news-form { display: flex; gap: 10px; flex-wrap: wrap; }
  .news-input {
    flex: 1;
    min-width: 200px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--white);
    padding: 14px 20px;
    font-family: "Archivo", sans-serif;
    font-size: 14px;
    transition: border-color 0.2s;
  }
  .news-input::placeholder { color: rgba(255, 255, 255, 0.25); }
  .news-input:focus { outline: none; border-color: var(--purple); }
  .news-btn { padding: 14px 26px; }
  .news-note {
    font-size: 13px;
    font-weight: 600;
    margin-top: 14px;
    color: var(--purple-light);
    min-height: 18px;
  }
</style>

<script>
  const form = document.getElementById('newsForm') as HTMLFormElement | null;
  const msg = document.getElementById('newsMsg');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (msg) msg.textContent = 'Gracias. Te escribiremos pronto.';
    form.reset();
  });
</script>
