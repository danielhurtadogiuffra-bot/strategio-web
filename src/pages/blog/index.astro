---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['Todos', 'Finanzas', 'Estrategia', 'Gestión', 'Liderazgo'];

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="Insights — Strategio" description="Análisis de alto nivel sobre finanzas corporativas, planeamiento estratégico y modelos de gestión para empresas peruanas.">
  <Navbar />

  <!-- Header -->
  <section class="blog-header">
    <div class="blog-header-inner">
      <span class="section-tag">Publicaciones</span>
      <h1 class="blog-h1">Insights <span class="accent">Strategio</span></h1>
      <p class="blog-lead">
        Perspectiva de alto nivel sobre finanzas, estrategia y gestión empresarial. Sin jerga
        innecesaria, con rigor analítico.
      </p>
    </div>
  </section>

  <!-- Filter tabs -->
  <section class="blog-filters">
    <div class="blog-filters-inner" id="filterTabs">
      {categories.map((cat, i) => (
        <button data-cat={cat} class={`filter-btn ${i === 0 ? 'active' : ''}`}>{cat}</button>
      ))}
    </div>
  </section>

  <!-- Posts grid -->
  <section class="blog-list">
    <div class="blog-list-inner">
      <div class="blog-grid" id="postsGrid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="blog-card post-card" data-category={post.data.category}>
            <div class="blog-card-top">
              <span class="blog-cat">{post.data.category}</span>
              <span class="blog-read">{post.data.readTime} min</span>
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <div class="blog-card-foot">
              <span>{formatDate(post.data.date)}</span>
              <span class="blog-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
      <div id="emptyState" class="empty-state" style="display:none;">
        <p>No hay artículos en esta categoría aún.</p>
      </div>
    </div>
  </section>

  <div class="blog-news"><NewsletterCTA variant="full" /></div>

  <Footer />
</Layout>

<style>
  .blog-header { padding: 180px 60px 60px; border-bottom: 1px solid var(--border); }
  .blog-header-inner { max-width: 1200px; margin: 0 auto; }
  .blog-h1 {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--white);
    margin: 20px 0 18px;
  }
  .blog-h1 .accent { color: var(--purple-light); }
  .blog-lead { font-size: 16px; line-height: 1.7; color: rgba(255, 255, 255, 0.5); font-weight: 300; max-width: 520px; }

  .blog-filters { position: sticky; top: 0; z-index: 40; background: rgba(13, 12, 20, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
  .blog-filters-inner { max-width: 1200px; margin: 0 auto; padding: 0 60px; display: flex; gap: 6px; overflow-x: auto; }
  .filter-btn {
    padding: 18px 18px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .filter-btn:hover { color: var(--white); }
  .filter-btn.active { color: var(--purple-light); border-color: var(--purple-light); }

  .blog-list { padding: 60px 60px 100px; min-height: 60vh; }
  .blog-list-inner { max-width: 1200px; margin: 0 auto; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .blog-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 26px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s, transform 0.25s;
  }
  .blog-card:hover { border-color: rgba(107, 53, 232, 0.45); transform: translateY(-4px); }
  .blog-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .blog-cat {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--purple-light);
    border: 1px solid rgba(139, 92, 246, 0.4);
    border-radius: 100px;
    padding: 4px 10px;
  }
  .blog-read { font-size: 12px; color: rgba(255, 255, 255, 0.35); }
  .blog-card-title { font-family: "Archivo", sans-serif; font-weight: 700; font-size: 19px; line-height: 1.25; color: var(--white); margin-bottom: 12px; }
  .blog-card-desc { font-size: 13px; line-height: 1.7; color: rgba(255, 255, 255, 0.45); font-weight: 300; flex: 1; }
  .blog-card-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; font-size: 12px; color: rgba(255, 255, 255, 0.3); }
  .blog-arrow { color: var(--purple-light); font-weight: 700; transition: transform 0.2s; }
  .blog-card:hover .blog-arrow { transform: translateX(4px); }
  .empty-state { padding: 80px 0; text-align: center; color: rgba(255, 255, 255, 0.4); font-size: 14px; }
  .blog-news { max-width: 1200px; margin: 0 auto; padding: 0 60px 100px; }

  @media (max-width: 768px) {
    .blog-header { padding: 140px 24px 48px; }
    .blog-filters-inner { padding: 0 24px; }
    .blog-list { padding: 48px 24px 80px; }
    .blog-grid { grid-template-columns: 1fr; }
    .blog-news { padding: 0 24px 80px; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const emptyState = document.getElementById('emptyState');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      let visible = 0;
      cards.forEach((card) => {
        const show = cat === 'Todos' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (emptyState) emptyState.style.display = visible > 0 ? 'none' : 'block';
    });
  });
</script>
