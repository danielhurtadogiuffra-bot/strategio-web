---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = ['Todos', 'Finanzas', 'Estrategia', 'Gestión', 'Liderazgo'];

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="Insights — Strategio" description="Análisis de alto nivel sobre finanzas corporativas, planeamiento estratégico y modelos de gestión para empresas peruanas.">
  <Navbar />

  <!-- Header -->
  <section class="pt-40 pb-20 bg-navy" style="border-bottom:1px solid #2A2740;">
    <div class="max-w-7xl mx-auto px-8">
      <p class="section-tag anim-up">Publicaciones</p>
      <h1 class="hero-title mt-4 anim-up d-100" style="font-size:clamp(2.5rem,5vw,5rem);">
        Insights<br/>
        <span style="color:#4D0FC1;">Strategio</span>
      </h1>
      <p class="text-base leading-relaxed mt-6 max-w-lg anim-up d-200" style="color:#9B97AA; font-weight:300;">
        Perspectiva de alto nivel sobre finanzas, estrategia y gestión empresarial. Sin jerga innecesaria, con rigor analítico.
      </p>
    </div>
  </section>

  <!-- Filter tabs -->
  <section class="sticky top-16 z-40" style="background:#1E1B26; border-bottom:1px solid #2A2740;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex gap-0 overflow-x-auto" id="filterTabs">
        {categories.map((cat, i) => (
          <button
            data-cat={cat}
            class="filter-btn px-6 py-4 text-xs font-bold tracking-widest uppercase whitespace-nowrap transition-colors border-b-2"
            style={i === 0 ? 'color:#4D0FC1; border-color:#4D0FC1;' : 'color:#9B97AA; border-color:transparent;'}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="py-20 bg-navy min-h-screen">
    <div class="max-w-7xl mx-auto px-8">

      <!-- Featured posts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-px mb-px" id="featuredGrid" style="background:#2A2740;">
        {posts.filter(p => p.data.featured).map(post => (
          <article
            class="p-10 hover-lift group cursor-pointer post-card"
            data-category={post.data.category}
            onclick={`window.location='/blog/${post.id}'`}
            style="background:#1E1B26;"
          >
            <div class="flex items-center justify-between mb-6">
              <span class="section-tag">{post.data.category}</span>
              <span class="text-xs" style="color:#9B97AA;">{post.data.readTime} min lectura</span>
            </div>
            <h2 class="text-2xl font-black leading-tight mb-4 transition-colors group-hover:text-purple" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">
              {post.data.title}
            </h2>
            <p class="text-sm leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs" style="color:#9B97AA;">{formatDate(post.data.date)}</span>
              <span class="text-sm font-black transition-transform group-hover:translate-x-1 inline-block" style="color:#4D0FC1;">→</span>
            </div>
          </article>
        ))}
      </div>

      <!-- Rest of posts -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px" id="postsGrid" style="background:#2A2740;">
        {posts.filter(p => !p.data.featured).map(post => (
          <article
            class="p-8 hover-lift group cursor-pointer post-card"
            data-category={post.data.category}
            onclick={`window.location='/blog/${post.id}'`}
            style="background:#0A0A19;"
          >
            <div class="flex items-center justify-between mb-4">
              <span class="section-tag" style="font-size:0.6rem;">{post.data.category}</span>
              <span class="text-xs" style="color:#9B97AA;">{post.data.readTime} min</span>
            </div>
            <h2 class="text-lg font-black leading-tight mb-3 transition-colors group-hover:text-purple" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">
              {post.data.title}
            </h2>
            <p class="text-xs leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs" style="color:#9B97AA;">{formatDate(post.data.date)}</span>
              <span class="text-sm font-black transition-transform group-hover:translate-x-1 inline-block" style="color:#4D0FC1;">→</span>
            </div>
          </article>
        ))}
      </div>

      <div id="emptyState" class="hidden py-20 text-center">
        <p class="text-sm" style="color:#9B97AA;">No hay artículos en esta categoría aún.</p>
      </div>

    </div>
  </section>

  <div class="max-w-7xl mx-auto px-8 py-20">
    <NewsletterCTA variant="full" />
  </div>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.post-card');
  const emptyState = document.getElementById('emptyState');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.cat;
      buttons.forEach(b => {
        (b as HTMLElement).style.color = '#9B97AA';
        (b as HTMLElement).style.borderColor = 'transparent';
      });
      (btn as HTMLElement).style.color = '#4D0FC1';
      (btn as HTMLElement).style.borderColor = '#4D0FC1';

      let visible = 0;
      cards.forEach(card => {
        const el = card as HTMLElement;
        if (cat === 'Todos' || el.dataset.category === cat) { el.style.display = ''; visible++; }
        else el.style.display = 'none';
      });
      emptyState.classList.toggle('hidden', visible > 0);
    });
  });
</script>
