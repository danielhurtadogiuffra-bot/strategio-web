---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}

const allPosts = (await getCollection('blog'))
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title={`${post.data.title} — Strategio`} description={post.data.description}>
  <Navbar />

  <header class="post-header">
    <div class="post-header-inner">
      <div class="post-meta-top">
        <a href="/blog" class="post-back">← Insights</a>
        <span class="post-sep">·</span>
        <span class="section-tag">{post.data.category}</span>
      </div>
      <h1 class="post-h1">{post.data.title}</h1>
      <p class="post-lead">{post.data.description}</p>
      <div class="post-byline">
        <div class="post-avatar"><span>S</span></div>
        <span class="post-author">{post.data.author}</span>
        <span class="post-sep">·</span>
        <span class="post-date">{formatDate(post.data.date)}</span>
        <span class="post-sep">·</span>
        <span class="post-date">{post.data.readTime} min lectura</span>
      </div>
    </div>
  </header>

  <article class="post-body">
    <div class="post-body-inner">
      <div class="prose-strategio">
        <Content />
      </div>

      <div class="post-share">
        <p>¿Te resultó útil?</p>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=https://strategio.pe/blog/${post.id}`}
          target="_blank"
          rel="noopener"
          class="btn-ghost"
        >
          Compartir en LinkedIn
        </a>
      </div>

      <NewsletterCTA variant="inline" />
    </div>
  </article>

  {allPosts.length > 0 && (
    <section class="post-related">
      <div class="post-related-inner">
        <span class="section-tag">También puede interesarte</span>
        <div class="related-grid">
          {allPosts.map((related) => (
            <a href={`/blog/${related.id}`} class="blog-card">
              <span class="blog-cat">{related.data.category}</span>
              <h3 class="blog-card-title">{related.data.title}</h3>
              <p class="blog-card-desc">{related.data.description}</p>
              <span class="blog-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="post-cta">
    <div class="cta-glow"></div>
    <div class="post-cta-inner">
      <span class="cta-eyebrow">¿Quieres profundizar?</span>
      <h2 class="post-cta-title">Apliquemos esto a tu organización.</h2>
      <p class="post-cta-desc">
        La primera sesión de diagnóstico es sin costo. En 60 minutos identificamos las oportunidades
        de mayor impacto específicas para tu empresa.
      </p>
      <a href="/#contacto" class="btn-primary">Agendar consulta gratuita →</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .post-header { padding: 180px 60px 56px; border-bottom: 1px solid var(--border); }
  .post-header-inner { max-width: 760px; margin: 0 auto; }
  .post-meta-top { display: flex; align-items: center; gap: 14px; margin-bottom: 28px; }
  .post-back { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255, 255, 255, 0.5); text-decoration: none; transition: color 0.2s; }
  .post-back:hover { color: var(--white); }
  .post-sep { color: rgba(255, 255, 255, 0.2); }
  .post-h1 { font-family: "Archivo", sans-serif; font-weight: 900; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.03em; color: var(--white); margin-bottom: 22px; }
  .post-lead { font-size: 17px; line-height: 1.7; color: rgba(255, 255, 255, 0.55); font-weight: 300; margin-bottom: 36px; }
  .post-byline { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .post-avatar { width: 32px; height: 32px; border-radius: 8px; background: var(--purple); display: flex; align-items: center; justify-content: center; }
  .post-avatar span { color: #fff; font-weight: 900; font-size: 13px; }
  .post-author { font-size: 14px; font-weight: 600; color: var(--white); }
  .post-date { font-size: 12px; font-weight: 600; color: var(--purple-light); }

  .post-body { padding: 64px 60px; }
  .post-body-inner { max-width: 760px; margin: 0 auto; }
  .post-share {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 0;
    margin: 56px 0 40px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .post-share p { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255, 255, 255, 0.45); }

  .post-related { padding: 90px 60px; background: var(--deep); border-top: 1px solid var(--border); }
  .post-related-inner { max-width: 1200px; margin: 0 auto; }
  .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 28px; }
  .blog-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px 30px;
    text-decoration: none;
    transition: border-color 0.3s, transform 0.25s;
    display: block;
  }
  .blog-card:hover { border-color: rgba(107, 53, 232, 0.45); transform: translateY(-4px); }
  .blog-cat { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--purple-light); }
  .blog-card-title { font-family: "Archivo", sans-serif; font-weight: 700; font-size: 20px; line-height: 1.25; color: var(--white); margin: 12px 0; }
  .blog-card-desc { font-size: 13px; line-height: 1.7; color: rgba(255, 255, 255, 0.45); font-weight: 300; }
  .blog-arrow { color: var(--purple-light); font-weight: 700; display: inline-block; margin-top: 14px; }

  .post-cta { padding: 120px 60px; text-align: center; position: relative; overflow: hidden; }
  .cta-glow { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 600px; background: radial-gradient(ellipse, rgba(107, 53, 232, 0.18), transparent 65%); pointer-events: none; }
  .post-cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .cta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--purple-light); display: block; margin-bottom: 18px; }
  .post-cta-title { font-family: "Archivo", sans-serif; font-weight: 900; font-size: clamp(26px, 3vw, 40px); line-height: 1.1; letter-spacing: -0.02em; color: var(--white); margin-bottom: 18px; }
  .post-cta-desc { font-size: 15px; line-height: 1.75; color: rgba(255, 255, 255, 0.45); font-weight: 300; margin-bottom: 32px; }

  @media (max-width: 768px) {
    .post-header { padding: 140px 24px 48px; }
    .post-body { padding: 48px 24px; }
    .post-related { padding: 64px 24px; }
    .related-grid { grid-template-columns: 1fr; }
    .post-cta { padding: 80px 24px; }
  }

  /* ── PROSE ── */
  .prose-strategio { color: rgba(255, 255, 255, 0.7); font-size: 1rem; line-height: 1.85; font-weight: 300; font-family: "Archivo", sans-serif; }
  .prose-strategio h2 { font-family: "Archivo", sans-serif; font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 900; color: var(--white); margin: 3rem 0 1.25rem; line-height: 1.1; letter-spacing: -0.01em; }
  .prose-strategio h3 { font-family: "Archivo", sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--purple-light); margin: 2rem 0 0.75rem; line-height: 1.2; }
  .prose-strategio p { margin: 0 0 1.5rem; }
  .prose-strategio strong { color: var(--white); font-weight: 700; }
  .prose-strategio em { color: var(--orange); font-style: italic; }
  .prose-strategio ul { margin: 0 0 1.5rem 0; list-style: none; padding: 0; }
  .prose-strategio ul li { position: relative; padding-left: 1.5rem; margin-bottom: 0.6rem; }
  .prose-strategio ul li::before { content: '→'; position: absolute; left: 0; color: var(--purple-light); font-weight: 700; }
  .prose-strategio ol { margin: 0 0 1.5rem 0; counter-reset: ol-counter; list-style: none; padding: 0; }
  .prose-strategio ol li { counter-increment: ol-counter; position: relative; padding-left: 2rem; margin-bottom: 0.6rem; }
  .prose-strategio ol li::before { content: counter(ol-counter) '.'; position: absolute; left: 0; color: var(--purple-light); font-weight: 900; font-family: "Archivo", sans-serif; }
  .prose-strategio blockquote { border-left: 3px solid var(--purple); padding: 0.5rem 0 0.5rem 1.5rem; margin: 2rem 0; font-size: 1.2rem; color: var(--white); font-weight: 300; font-style: italic; }
  .prose-strategio pre { background: #16152a; border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 2rem 0; overflow-x: auto; font-size: 0.85rem; color: var(--orange); }
  .prose-strategio code { background: #16152a; border-radius: 6px; padding: 0.15rem 0.4rem; font-size: 0.85rem; color: var(--orange); }
  .prose-strategio hr { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
  .prose-strategio a { color: var(--purple-light); text-decoration: underline; text-underline-offset: 3px; }
  .prose-strategio a:hover { color: var(--white); }
</style>
