---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}

const allPosts = (await getCollection('blog'))
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title={`${post.data.title} — Strategio`} description={post.data.description}>
  <Navbar />

  <header class="pt-40 pb-16 bg-navy" style="border-bottom:1px solid #2A2740;">
    <div class="max-w-3xl mx-auto px-8">
      <div class="flex items-center gap-4 mb-8 anim-up">
        <a href="/blog" class="text-xs font-bold tracking-widest uppercase transition-colors" style="color:#9B97AA;">
          ← Insights
        </a>
        <span style="color:#2A2740;">·</span>
        <span class="section-tag">{post.data.category}</span>
      </div>

      <h1 class="hero-title mb-6 anim-up d-100" style="font-size:clamp(2rem,5vw,3.5rem);">
        {post.data.title}
      </h1>

      <p class="text-base leading-relaxed mb-10 anim-up d-200" style="color:#9B97AA; font-weight:300; max-width:600px;">
        {post.data.description}
      </p>

      <div class="flex items-center gap-6 anim-up d-300">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 flex items-center justify-center" style="background:#4D0FC1;">
            <span class="text-white text-xs font-black" style="font-family:'Archivo',sans-serif;">S</span>
          </div>
          <p class="text-sm font-semibold" style="color:#F8F8FF;">{post.data.author}</p>
        </div>
        <span style="color:#2A2740;">·</span>
        <span class="text-xs font-bold" style="color:#FF985C;">{formatDate(post.data.date)}</span>
        <span style="color:#2A2740;">·</span>
        <span class="text-xs font-bold" style="color:#FF985C;">{post.data.readTime} min lectura</span>
      </div>
    </div>
  </header>

  <article class="py-16 bg-navy">
    <div class="max-w-3xl mx-auto px-8">
      <div class="prose-strategio">
        <Content />
      </div>

      <div class="py-6 mt-16 mb-10 flex items-center justify-between" style="border-top:1px solid #2A2740; border-bottom:1px solid #2A2740;">
        <p class="text-xs font-bold uppercase tracking-widest" style="color:#9B97AA;">¿Le resultó útil?</p>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=https://strategio.pe/blog/${post.id}`}
          target="_blank" rel="noopener"
          class="btn-outline text-xs px-4 py-2"
        >
          Compartir en LinkedIn
        </a>
      </div>

      <NewsletterCTA variant="inline" />
    </div>
  </article>

  {allPosts.length > 0 && (
    <section class="py-20" style="background:#1E1B26; border-top:1px solid #2A2740;">
      <div class="max-w-7xl mx-auto px-8">
        <p class="section-tag mb-10">También puede interesarle</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px" style="background:#2A2740;">
          {allPosts.map(related => (
            <a href={`/blog/${related.id}`} class="p-10 hover-lift group block" style="background:#0A0A19;">
              <span class="section-tag" style="font-size:0.6rem;">{related.data.category}</span>
              <h3 class="text-xl font-black leading-tight mt-3 mb-3 group-hover:text-purple transition-colors" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">
                {related.data.title}
              </h3>
              <p class="text-xs leading-relaxed" style="color:#9B97AA;">{related.data.description}</p>
              <span class="text-sm font-black mt-4 inline-block transition-transform group-hover:translate-x-1" style="color:#4D0FC1;">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-20" style="background:#4D0FC1;">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:rgba(248,248,255,0.6);">¿Quiere profundizar?</p>
      <h2 class="text-3xl font-black mb-6" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">
        Apliquemos esto a su organización.
      </h2>
      <p class="text-sm leading-relaxed mb-8" style="color:rgba(248,248,255,0.7); font-weight:300;">
        La primera sesión de diagnóstico es sin costo. En 60 minutos identificamos las oportunidades de mayor impacto específicas para su empresa.
      </p>
      <a href="/#contacto" class="inline-flex items-center gap-2 px-8 py-4 font-bold text-sm uppercase tracking-widest transition-all" style="background:#F8F8FF; color:#4D0FC1; font-family:'Archivo',sans-serif;">
        Agendar consulta gratuita
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .prose-strategio {
    color: #D8D5E2; font-size: 1rem; line-height: 1.85;
    font-weight: 300; font-family: "Archivo", sans-serif;
  }
  .prose-strategio h2 {
    font-family: "Archivo", sans-serif; font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 900; color: #F8F8FF; margin: 3rem 0 1.25rem;
    line-height: 1.1; letter-spacing: -0.01em;
  }
  .prose-strategio h3 {
    font-family: "Archivo", sans-serif; font-size: 1.2rem;
    font-weight: 700; color: #4D0FC1; margin: 2rem 0 0.75rem; line-height: 1.2;
  }
  .prose-strategio p { margin: 0 0 1.5rem; color: #D8D5E2; }
  .prose-strategio strong { color: #F8F8FF; font-weight: 700; }
  .prose-strategio em { color: #FF985C; font-style: italic; }
  .prose-strategio ul { margin: 0 0 1.5rem 0; list-style: none; padding: 0; }
  .prose-strategio ul li { position: relative; padding-left: 1.5rem; margin-bottom: 0.6rem; color: #D8D5E2; }
  .prose-strategio ul li::before { content: '→'; position: absolute; left: 0; color: #4D0FC1; font-weight: 700; }
  .prose-strategio ol { margin: 0 0 1.5rem 0; counter-reset: ol-counter; list-style: none; padding: 0; }
  .prose-strategio ol li { counter-increment: ol-counter; position: relative; padding-left: 2rem; margin-bottom: 0.6rem; color: #D8D5E2; }
  .prose-strategio ol li::before { content: counter(ol-counter) '.'; position: absolute; left: 0; color: #4D0FC1; font-weight: 900; font-family: "Archivo", sans-serif; }
  .prose-strategio blockquote { border-left: 3px solid #4D0FC1; padding: 0.5rem 0 0.5rem 1.5rem; margin: 2rem 0; font-size: 1.2rem; color: #F8F8FF; font-weight: 300; font-style: italic; }
  .prose-strategio pre { background: #1E1B26; border: 1px solid #2A2740; padding: 1.5rem; margin: 2rem 0; overflow-x: auto; font-size: 0.85rem; color: #FF985C; }
  .prose-strategio code { background: #1E1B26; padding: 0.15rem 0.4rem; font-size: 0.85rem; color: #FF985C; }
  .prose-strategio hr { border: none; border-top: 1px solid #2A2740; margin: 3rem 0; }
  .prose-strategio a { color: #4D0FC1; text-decoration: underline; text-underline-offset: 3px; }
  .prose-strategio a:hover { color: #6B2FE0; }
</style>
