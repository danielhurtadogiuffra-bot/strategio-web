---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}

const allPosts = (await getCollection('blog'))
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title={`${post.data.title} — Strategio`} description={post.data.description}>
  <Navbar />

  <!-- Article header -->
  <header class="pt-40 pb-16 bg-obsidian border-b" style="border-color:#2e2e2e;">
    <div class="max-w-3xl mx-auto px-8">
      <div class="flex items-center gap-4 mb-8 animate-fade-in-up">
        <a href="/blog" class="text-xs tracking-widest uppercase hover:text-gold transition-colors" style="color:#a8a09b;">
          ← Insights
        </a>
        <span style="color:#2e2e2e;">·</span>
        <span class="section-label">{post.data.category}</span>
      </div>

      <h1 class="font-display font-light leading-tight mb-6 animate-fade-in-up delay-100" style="font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,5vw,3.5rem); color:#f5f0e8;">
        {post.data.title}
      </h1>

      <p class="text-base leading-relaxed mb-10 animate-fade-in-up delay-200" style="color:#a8a09b; font-weight:300; max-width:600px;">
        {post.data.description}
      </p>

      <div class="flex items-center gap-6 animate-fade-in-up delay-300">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-smoke border flex items-center justify-center" style="border-color:#8a6f2e;">
            <span class="text-gold text-xs" style="font-family:'Cormorant Garamond',serif;">S</span>
          </div>
          <div>
            <p class="text-ivory text-sm font-medium">{post.data.author}</p>
          </div>
        </div>
        <span style="color:#2e2e2e;">·</span>
        <span class="text-xs" style="color:#8a6f2e;">{formatDate(post.data.date)}</span>
        <span style="color:#2e2e2e;">·</span>
        <span class="text-xs" style="color:#8a6f2e;">{post.data.readTime} min lectura</span>
      </div>
    </div>
  </header>

  <!-- Article body -->
  <article class="py-16 bg-obsidian">
    <div class="max-w-3xl mx-auto px-8">
      <div class="prose-strategio">
        <Content />
      </div>

      <!-- Share -->
      <div class="border-t border-b py-6 mt-16 mb-10 flex items-center justify-between" style="border-color:#2e2e2e;">
        <p class="text-xs" style="color:#a8a09b; letter-spacing:0.1em; text-transform:uppercase;">¿Le resultó útil?</p>
        <div class="flex gap-3">
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=https://strategio.pe/blog/${post.id}`}
            target="_blank" rel="noopener"
            class="btn-outline text-xs px-4 py-2"
          >
            Compartir en LinkedIn
          </a>
        </div>
      </div>

      <!-- Newsletter inline -->
      <NewsletterCTA variant="inline" />
    </div>
  </article>

  <!-- Related posts -->
  {allPosts.length > 0 && (
    <section class="py-20 bg-charcoal border-t" style="border-color:#2e2e2e;">
      <div class="max-w-7xl mx-auto px-8">
        <p class="section-label mb-10">También puede interesarle</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-smoke">
          {allPosts.map(related => (
            <a href={`/blog/${related.id}`} class="bg-charcoal p-10 hover-lift group block">
              <span class="section-label" style="font-size:0.6rem;">{related.data.category}</span>
              <h3 class="font-display text-xl text-ivory font-light leading-tight mt-3 mb-3 group-hover:text-gold transition-colors" style="font-family:'Cormorant Garamond',serif;">
                {related.data.title}
              </h3>
              <p class="text-xs leading-relaxed" style="color:#a8a09b;">{related.data.description}</p>
              <span class="text-gold text-sm mt-4 inline-block group-hover:translate-x-1 transition-transform">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 bg-obsidian border-t" style="border-color:#2e2e2e;">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <p class="section-label mb-4">¿Quiere profundizar?</p>
      <h2 class="font-display text-3xl text-ivory font-light mb-6" style="font-family:'Cormorant Garamond',serif;">
        Apliquemos esto a<br/>
        <span class="text-gold italic">su organización.</span>
      </h2>
      <p class="text-sm leading-relaxed mb-8" style="color:#a8a09b; font-weight:300;">
        La primera sesión de diagnóstico es sin costo. En 60 minutos identificamos las oportunidades de mayor impacto específicas para su empresa.
      </p>
      <a href="/#contacto" class="btn-primary">
        Agendar consulta gratuita
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Article prose styles */
  .prose-strategio {
    color: #d4cdc6;
    font-size: 1rem;
    line-height: 1.85;
    font-weight: 300;
  }
  .prose-strategio h2 {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 300;
    color: #f5f0e8;
    margin: 3rem 0 1.25rem;
    line-height: 1.2;
  }
  .prose-strategio h3 {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: #e8c97a;
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }
  .prose-strategio p {
    margin: 0 0 1.5rem;
    color: #c4bdb6;
  }
  .prose-strategio strong {
    color: #f5f0e8;
    font-weight: 500;
  }
  .prose-strategio em {
    color: #c9a84c;
    font-style: italic;
  }
  .prose-strategio ul {
    margin: 0 0 1.5rem 1.5rem;
    list-style: none;
    padding: 0;
  }
  .prose-strategio ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.6rem;
    color: #c4bdb6;
  }
  .prose-strategio ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-size: 0.85rem;
  }
  .prose-strategio ol {
    margin: 0 0 1.5rem 1.5rem;
    counter-reset: ol-counter;
    list-style: none;
    padding: 0;
  }
  .prose-strategio ol li {
    counter-increment: ol-counter;
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.6rem;
    color: #c4bdb6;
  }
  .prose-strategio ol li::before {
    content: counter(ol-counter) '.';
    position: absolute;
    left: 0;
    color: #c9a84c;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.1rem;
  }
  .prose-strategio blockquote {
    border-left: 2px solid #c9a84c;
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 1.25rem;
    color: #f5f0e8;
    font-style: italic;
  }
  .prose-strategio pre {
    background: #141414;
    border: 1px solid #2e2e2e;
    padding: 1.5rem;
    margin: 2rem 0;
    overflow-x: auto;
    font-size: 0.85rem;
    color: #c9a84c;
  }
  .prose-strategio code {
    background: #141414;
    padding: 0.15rem 0.4rem;
    font-size: 0.85rem;
    color: #c9a84c;
  }
  .prose-strategio hr {
    border: none;
    border-top: 1px solid #2e2e2e;
    margin: 3rem 0;
  }
  .prose-strategio a {
    color: #c9a84c;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-strategio a:hover {
    color: #e8c97a;
  }
</style>
