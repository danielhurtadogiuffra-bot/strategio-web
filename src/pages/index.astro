---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout>
  <Navbar />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-navy">
    <div class="absolute inset-0 opacity-[0.03]" style="
      background-image: linear-gradient(#4D0FC1 1px, transparent 1px),
                        linear-gradient(90deg, #4D0FC1 1px, transparent 1px);
      background-size: 60px 60px;
    "></div>
    <div class="absolute right-0 top-0 bottom-0 w-px" style="background:linear-gradient(to bottom, transparent, #4D0FC1, transparent); opacity:0.3;"></div>
    <span class="absolute right-8 bottom-16 font-heading text-[20rem] font-black opacity-[0.02] select-none leading-none" style="color:#F8F8FF; font-family:'Archivo',sans-serif;">S</span>

    <div class="relative max-w-7xl mx-auto px-8 pt-40 pb-32 w-full">
      <div class="max-w-4xl">
        <p class="section-tag anim-up">Consultoría Estratégica · Lima, Perú</p>

        <h1 class="hero-title mt-6 anim-up d-100">
          Decisiones que<br/>
          <span style="color:#4D0FC1;">transforman</span><br/>
          organizaciones.
        </h1>

        <span class="purple-line anim-line d-300"></span>

        <p class="text-base md:text-lg leading-relaxed max-w-xl anim-up d-300" style="color:#9B97AA; font-weight:300;">
          Integramos análisis financiero de alto nivel, optimización de procesos y visión ejecutiva para construir estructuras sólidas, éticas y escalables.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-10 anim-up d-500">
          <a href="#contacto" class="btn-primary">
            Agendar una consulta
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#servicios" class="btn-outline-white">Conocer servicios</a>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px mt-20 anim-fade d-700" style="background:#2A2740;">
        {[
          ['11+', 'Años en B2B'],
          ['50+', 'Empresas asesoradas'],
          ['80+', 'Proyectos ejecutados'],
          ['$1B+', 'En ingresos asesorados'],
        ].map(([num, label]) => (
          <div class="px-8 py-8" style="background:#1E1B26;">
            <p class="card-stat">{num}</p>
            <p class="text-xs mt-2 uppercase tracking-widest" style="color:#9B97AA;">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- NOSOTROS -->
  <section id="nosotros" class="py-32" style="background:#1E1B26;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

        <div class="relative">
          <div class="p-12 relative" style="background:#0A0A19; border:1px solid #2A2740;">
            <span class="purple-line"></span>
            <p class="text-2xl leading-relaxed italic" style="font-family:'Archivo',sans-serif; font-weight:300; color:#F8F8FF;">
              "Las organizaciones que sobreviven no son las más grandes, sino las que toman mejores decisiones."
            </p>
            <div class="mt-8 flex items-center gap-4">
              <div class="w-10 h-10 flex items-center justify-center" style="background:#4D0FC1;">
                <svg width="20" height="20" viewBox="0 0 90 90" fill="white">
                  <polygon points="5,5 29,5 5,29"/>
                  <rect x="33" y="5" width="24" height="24"/>
                  <polygon points="61,5 85,5 85,29"/>
                  <polygon points="5,33 5,57 29,45"/>
                  <polygon points="85,33 85,57 61,45"/>
                  <polygon points="5,61 5,85 29,85"/>
                  <rect x="33" y="61" width="24" height="24"/>
                  <polygon points="61,85 85,85 85,61"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold" style="color:#F8F8FF;">Equipo Strategio</p>
                <p class="text-xs" style="color:#9B97AA;">Dirección Estratégica</p>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-3 -right-3 w-20 h-20" style="border:2px solid #4D0FC1; opacity:0.3;"></div>
          <div class="absolute -top-3 -left-3 w-10 h-10" style="border:2px solid #FF985C; opacity:0.3;"></div>
        </div>

        <div>
          <p class="section-tag">Quiénes somos</p>
          <h2 class="section-title mt-4">
            Más de una década<br/>construyendo<br/>
            <span style="color:#4D0FC1;">visión corporativa.</span>
          </h2>
          <span class="purple-line"></span>
          <p class="text-sm leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">
            Strategio nació con una convicción: que la consultoría de primer nivel no debería ser exclusiva de las corporaciones globales. Las empresas medianas y en crecimiento merecen el mismo rigor analítico y la misma profundidad estratégica.
          </p>
          <p class="text-sm leading-relaxed mb-10" style="color:#9B97AA; font-weight:300;">
            Operamos desde Lima con metodología de clase mundial, integrando perspectiva local, expertise financiero y visión ejecutiva en cada encargo que aceptamos.
          </p>
          <div class="grid grid-cols-2 gap-6">
            {[
              ['Ética profesional', 'Integridad en cada análisis'],
              ['Rigor analítico', 'Datos sobre intuición'],
              ['Visión ejecutiva', 'Más allá de los números'],
              ['Resultados medibles', 'Impacto verificable'],
            ].map(([title, sub]) => (
              <div class="flex gap-3">
                <div class="w-1.5 h-1.5 rounded-full mt-1.5 shrink-0" style="background:#4D0FC1;"></div>
                <div>
                  <p class="text-sm font-semibold" style="color:#F8F8FF;">{title}</p>
                  <p class="text-xs mt-0.5" style="color:#9B97AA;">{sub}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- SERVICIOS -->
  <section id="servicios" class="py-32 bg-navy">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div>
          <p class="section-tag">Lo que hacemos</p>
          <h2 class="section-title mt-4">
            Tres disciplinas,<br/>
            <span style="color:#4D0FC1;">un propósito.</span>
          </h2>
        </div>
        <p class="text-sm leading-relaxed max-w-sm" style="color:#9B97AA; font-weight:300;">
          Cada servicio está diseñado para atacar los problemas más complejos de las organizaciones en crecimiento.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px" style="background:#2A2740;">

        <div class="card-service hover-lift relative">
          <span class="num-accent">01</span>
          <div class="w-10 h-10 flex items-center justify-center mb-6" style="background:#4D0FC1;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <p class="section-tag mb-3">Finanzas Corporativas</p>
          <h3 class="text-xl font-black mb-4 leading-tight" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">Visión financiera de alto impacto</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">
            Transformamos los registros contables en herramientas estratégicas de decisión. Valorización de empresas, estructuración de deuda, análisis de rentabilidad y gestión del capital de trabajo.
          </p>
          <ul class="flex flex-col gap-2">
            {['Valorización y due diligence', 'Planeación financiera integral', 'Reestructuración de pasivos', 'Análisis de inversiones y M&A'].map(item => (
              <li class="flex gap-2 items-start text-xs" style="color:#9B97AA;">
                <span style="color:#4D0FC1; margin-top:1px;">→</span> {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="card-service hover-lift relative">
          <span class="num-accent">02</span>
          <div class="w-10 h-10 flex items-center justify-center mb-6" style="background:#4D0FC1;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <p class="section-tag mb-3">Planeamiento Estratégico</p>
          <h3 class="text-xl font-black mb-4 leading-tight" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">Dirección con propósito y precisión</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">
            Diseñamos la hoja de ruta que convierte la visión en acción ejecutable. Desde el diagnóstico inicial hasta la implementación de OKRs y tableros de control gerencial.
          </p>
          <ul class="flex flex-col gap-2">
            {['Diagnóstico organizacional', 'Diseño de KPIs y OKRs', 'Plan estratégico 3-5 años', 'Balanced scorecard'].map(item => (
              <li class="flex gap-2 items-start text-xs" style="color:#9B97AA;">
                <span style="color:#4D0FC1; margin-top:1px;">→</span> {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="card-service hover-lift relative">
          <span class="num-accent">03</span>
          <div class="w-10 h-10 flex items-center justify-center mb-6" style="background:#4D0FC1;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </div>
          <p class="section-tag mb-3">Modelos de Gestión</p>
          <h3 class="text-xl font-black mb-4 leading-tight" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">Estructura para el crecimiento sostenido</h3>
          <p class="text-sm leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">
            Diseñamos modelos operativos adaptados a la complejidad de cada industria. Procesos, estructura organizacional y sistemas de control para garantizar crecimiento ordenado.
          </p>
          <ul class="flex flex-col gap-2">
            {['Rediseño de procesos core', 'Estructura organizacional', 'Sistemas de control interno', 'Gobierno corporativo'].map(item => (
              <li class="flex gap-2 items-start text-xs" style="color:#9B97AA;">
                <span style="color:#4D0FC1; margin-top:1px;">→</span> {item}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>


  <!-- METODOLOGÍA -->
  <section id="metodologia" class="py-32" style="background:#1E1B26;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20">
        <p class="section-tag">Cómo trabajamos</p>
        <h2 class="section-title mt-4">
          Un proceso diseñado para<br/>
          <span style="color:#4D0FC1;">resultados reales.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-px" style="background:#2A2740;">
        {[
          { num: '01', title: 'Diagnóstico', desc: 'Análisis profundo de la organización: finanzas, procesos, estructura y cultura. Sin supuestos.' },
          { num: '02', title: 'Diseño', desc: 'Construimos la solución a medida, con benchmarks del sector y mejores prácticas internacionales.' },
          { num: '03', title: 'Implementación', desc: 'Acompañamiento activo durante la ejecución. No entregamos documentos, entregamos cambios.' },
          { num: '04', title: 'Seguimiento', desc: 'Medición continua de resultados. Ajustamos la estrategia con base en datos, no en opiniones.' },
        ].map(step => (
          <div class="p-10 relative hover-lift" style="background:#0A0A19;">
            <p class="text-7xl font-black absolute top-4 right-4 opacity-[0.07]" style="color:#F8F8FF; font-family:'Archivo',sans-serif; line-height:1;">{step.num}</p>
            <div class="w-8 h-8 flex items-center justify-center mb-6" style="background:#4D0FC1;">
              <span class="text-xs font-black text-white" style="font-family:'Archivo',sans-serif;">{step.num}</span>
            </div>
            <h3 class="text-lg font-black mb-3" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">{step.title}</h3>
            <p class="text-sm leading-relaxed" style="color:#9B97AA; font-weight:300;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- TESTIMONIALES -->
  <section id="resultados" class="py-32 bg-navy">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">

        <div>
          <p class="section-tag">Lo que dicen nuestros clientes</p>
          <h2 class="section-title mt-4">
            El impacto habla<br/>
            <span style="color:#4D0FC1;">por sí solo.</span>
          </h2>
          <span class="purple-line"></span>
          <p class="text-sm leading-relaxed max-w-sm" style="color:#9B97AA; font-weight:300;">
            Trabajamos con líderes empresariales que entienden que la consultoría de calidad no es un gasto, es la inversión de mayor retorno.
          </p>
          <div class="mt-10 grid grid-cols-2 gap-4">
            <div class="p-6" style="background:#1E1B26; border:1px solid #2A2740;">
              <p class="card-stat text-3xl">40%</p>
              <p class="text-xs mt-2 uppercase tracking-widest" style="color:#9B97AA;">Reducción promedio de costos operativos</p>
            </div>
            <div class="p-6" style="background:#1E1B26; border:1px solid #2A2740;">
              <p class="card-stat text-3xl">2.8x</p>
              <p class="text-xs mt-2 uppercase tracking-widest" style="color:#9B97AA;">ROI promedio en proyectos estratégicos</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-6">
          {[
            { initial: 'C', name: 'Carlos M.', role: 'CEO · Empresa industrial, Lima', quote: 'Strategio nos ayudó a identificar ineficiencias que teníamos invisibles en el P&L. En seis meses redujimos costos en un 38% sin comprometer la operación. Una visión que no teníamos internamente.' },
            { initial: 'A', name: 'Ana L.', role: 'Directora General · Grupo retail, Perú', quote: 'Necesitábamos ordenar la casa antes de escalar. Strategio diseñó el modelo de gestión que nos faltaba: gobierno, procesos y finanzas alineados. Hoy somos una empresa diferente.' },
            { initial: 'R', name: 'Roberto V.', role: 'Gerente de Inversiones · Family office', quote: 'El due diligence que realizaron fue determinante en la decisión de inversión. Rigor, profundidad y recomendaciones accionables. Exactamente lo que necesitábamos para cerrar la operación.' },
          ].map(t => (
            <div class="testimonial-card">
              <p class="text-2xl mb-3" style="color:#4D0FC1; font-family:'Archivo',sans-serif; font-weight:900;">"</p>
              <p class="text-sm leading-relaxed mb-6" style="color:#D8D5E2; font-weight:300;">{t.quote}</p>
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 flex items-center justify-center" style="background:#4D0FC1;">
                  <span class="text-white text-sm font-black" style="font-family:'Archivo',sans-serif;">{t.initial}</span>
                </div>
                <div>
                  <p class="text-sm font-semibold" style="color:#F8F8FF;">{t.name}</p>
                  <p class="text-xs" style="color:#9B97AA;">{t.role}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- CTA BANNER — purple bg bold moment -->
  <section class="py-20" style="background:#4D0FC1;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color:rgba(248,248,255,0.6);">¿Listo para el siguiente nivel?</p>
          <h2 class="text-3xl md:text-4xl font-black leading-tight" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">
            Su organización merece<br/>claridad estratégica.
          </h2>
        </div>
        <a href="#contacto" class="shrink-0 inline-flex items-center gap-2 px-8 py-4 font-bold text-sm uppercase tracking-widest transition-all duration-300" style="background:#F8F8FF; color:#4D0FC1; font-family:'Archivo',sans-serif;">
          Agendar diagnóstico gratuito
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>


  <!-- SITUACIONES -->
  <section class="py-32" style="background:#1E1B26;">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div>
          <p class="section-tag">Situaciones que resolvemos</p>
          <h2 class="section-title mt-4">
            ¿Se reconoce en<br/>
            <span style="color:#4D0FC1;">alguna de estas?</span>
          </h2>
        </div>
        <p class="text-sm leading-relaxed max-w-sm" style="color:#9B97AA; font-weight:300;">
          Cada organización es única, pero los desafíos estratégicos tienen patrones. Estos son los más comunes que acompañamos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:#2A2740;">
        {[
          { icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`, title: 'La empresa que creció rápido y perdió el control', desc: 'Las ventas subieron, pero los márgenes bajaron. Los procesos que funcionaban con 20 personas ya no escalan. Nadie sabe exactamente dónde se va el dinero.', tag: 'Gestión · Finanzas' },
          { icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`, title: 'El negocio familiar que quiere institucionalizar', desc: 'La segunda generación entra a la empresa. O se busca un gerente externo. O simplemente el fundador quiere que el negocio funcione sin depender de él solo.', tag: 'Gestión · Gobierno' },
          { icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`, title: 'La empresa con caja ajustada a pesar de vender bien', desc: 'Los ingresos existen, pero la liquidez siempre está comprometida. Los plazos de pago se alargan, los proveedores presionan y la deuda de corto plazo se renueva indefinidamente.', tag: 'Finanzas · Tesorería' },
          { icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`, title: 'La organización que planea pero no ejecuta', desc: 'El plan estratégico se presenta en enero con mucho entusiasmo. En junio nadie lo recuerda. Los objetivos se posponen, las prioridades cambian y el equipo pierde el norte.', tag: 'Estrategia · Ejecución' },
          { icon: `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`, title: 'El directivo que necesita argumentos financieros sólidos', desc: 'Una adquisición, una inversión importante, una ronda de financiamiento o una presentación ante accionistas. Se necesita un análisis que aguante el escrutinio externo.', tag: 'Finanzas · M&A' },
          { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, title: 'La empresa que no sabe qué tan valiosa es', desc: 'Se abre la posibilidad de vender, fusionarse, entrar un socio o acceder a crédito. Nadie tiene claridad sobre el valor real del negocio ni sobre qué lo sostiene o lo erosiona.', tag: 'Finanzas · Valorización' },
        ].map(sit => (
          <div class="p-8 hover-lift group" style="background:#0A0A19;">
            <div class="w-9 h-9 flex items-center justify-center mb-5" style="background:#4D0FC1;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" set:html={sit.icon}></svg>
            </div>
            <h3 class="text-lg font-black leading-snug mb-3" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">{sit.title}</h3>
            <p class="text-xs leading-relaxed mb-5" style="color:#9B97AA; font-weight:300;">{sit.desc}</p>
            <span class="text-xs font-bold uppercase tracking-widest" style="color:#FF985C;">{sit.tag}</span>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="#contacto" class="btn-outline">Si se reconoce en alguna, conversemos →</a>
      </div>
    </div>
  </section>


  <!-- EQUIPO -->
  <section id="equipo" class="py-32 bg-navy">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16">
        <p class="section-tag">El equipo</p>
        <h2 class="section-title mt-4">
          Las personas detrás<br/>
          <span style="color:#4D0FC1;">de cada encargo.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background:#2A2740;">

        <div class="p-10 hover-lift" style="background:#1E1B26;">
          <div class="w-16 h-16 mb-6 flex items-center justify-center" style="background:#4D0FC1;">
            <span class="text-3xl font-black text-white" style="font-family:'Archivo',sans-serif;">D</span>
          </div>
          <h3 class="text-xl font-black mb-1" style="font-family:'Archivo',sans-serif; color:#F8F8FF;">Daniel Hurtado</h3>
          <p class="section-tag mb-4" style="font-size:0.6rem;">Fundador &amp; Director</p>
          <p class="text-xs leading-relaxed mb-6" style="color:#9B97AA; font-weight:300;">
            Más de 11 años asesorando a empresas medianas en finanzas corporativas, planeamiento estratégico y reestructuración organizacional en el mercado peruano.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Finanzas Corporativas', 'M&A', 'Estrategia'].map(tag => (
