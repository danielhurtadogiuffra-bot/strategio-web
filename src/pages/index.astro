---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-PE', { year: 'numeric', month: 'long', day: 'numeric' });
}

const services = [
  {
    name: 'Estrategia y asesoría financiera',
    desc: 'No solo gestionamos recursos; diseñamos la estructura de capital y rentabilidad necesaria para asegurar la salud y el valor de tu organización a largo plazo.',
    note: '→ sin estructura financiera, el crecimiento es solo ruido',
    icon: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  },
  {
    name: 'Asesoría contable y tercerización',
    desc: 'Ponemos la casa en orden. Transformamos el registro contable en una herramienta ética y precisa, permitiendo una toma de decisiones impecable y sin sorpresas.',
    note: '→ el orden contable es la base de todo lo demás',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/>',
  },
  {
    name: 'Control de gestión',
    desc: 'Atravesamos el caos mediante indicadores clave (KPIs) que te permiten mantener el mando de tu operación y anticipar el futuro con seguridad.',
    note: '→ medir bien es decidir bien',
    icon: '<path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/><circle cx="19" cy="5" r="3"/>',
  },
];
---

<Layout>
  <Navbar />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-vp-light"></div>
    <div class="hero-vp-ground"></div>

    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Consultoría estratégica · Perú
    </div>
    <h1 class="hero-title">
      Atravesamos <span class="script-accent">el caos</span><br />
      para encontrar <span class="accent">el orden.</span>
    </h1>
    <p class="hero-desc">
      Asesoramos a organizaciones que buscan claridad, estructura y dirección. Construimos el
      orden interno que hace posible el crecimiento y multiplica resultados.
    </p>
    <div class="hero-actions">
      <a href="/#contacto" class="btn-primary">Hablemos de tu empresa →</a>
      <a href="/#servicios" class="btn-ghost">Nuestros servicios</a>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="stat-item reveal d1">
      <div class="stat-number">+<span>50</span></div>
      <div class="stat-label">Clientes</div>
    </div>
    <div class="stat-item reveal d2">
      <div class="stat-number">11<span>+</span></div>
      <div class="stat-label">Años en consultoría B2B</div>
    </div>
    <div class="stat-item reveal d3">
      <div class="stat-number">+<span>80</span></div>
      <div class="stat-label">Proyectos completados</div>
    </div>
    <div class="stat-item reveal d4">
      <div class="stat-number">$1B<span>+</span></div>
      <div class="stat-label">En revenue asesorado</div>
    </div>
  </section>

  <!-- PROBLEMA -->
  <section class="problema" id="diagnostico">
    <div class="problema-left">
      <h2 class="problema-title reveal-left">
        Atravesar <span class="script-inline">el caos</span><br />
        para encontrar<br />
        <span class="underline-accent">el orden<svg viewBox="0 0 160 10" height="8" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2,5 C15,3 35,7 55,5 C75,3 95,7 115,5 C132,3 148,6.5 158,5" stroke="#6B35E8" stroke-width="4" fill="none" stroke-linecap="round" opacity="0.95"/>
          <path d="M3,7 C20,5.5 42,8.5 62,7 C82,5.5 102,8.5 122,7 C138,5.5 152,7.5 158,7" stroke="#7B45F8" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.55"/>
        </svg></span>.
      </h2>
    </div>
    <div class="problema-right">
      <p class="problema-intro reveal">
        Integramos el <strong>análisis financiero</strong> de alto nivel, la
        <strong>optimización de procesos</strong> y la <strong>visión directiva</strong> para
        construir estructuras sólidas, éticas y escalables que aseguran un
        <strong>crecimiento sostenible</strong>.
      </p>
      <div class="sintoma-grid">
        <div class="sintoma reveal d1">
          <div class="sintoma-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6B35E8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <div class="sintoma-desc">
            Colaboramos bajo <strong>estándares globales</strong> de
            <strong>gestión y control</strong> para potenciar la <strong>eficiencia</strong>
            operativa y el <strong>bienestar financiero</strong>, garantizando que cada decisión
            esté respaldada por datos precisos y diagnósticos profundos.
          </div>
        </div>
        <div class="sintoma reveal d2">
          <div class="sintoma-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6B35E8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5h7M17.5 14v7"/></svg>
          </div>
          <div class="sintoma-desc">
            Como especialistas en <strong>planeamiento estratégico</strong> y
            <strong>finanzas corporativas</strong>, transformamos la complejidad de tu
            organización en una ventaja competitiva, trazando un mejor camino hacia la
            rentabilidad y el <strong>éxito</strong>.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="services" id="servicios">
    <div class="services-header">
      <div class="reveal-left">
        <div class="services-eyebrow"><span class="services-eyebrow-dot"></span>Servicios</div>
        <h2 class="services-title">
          El <span class="hl">orden</span> es el génesis del<br />
          <span class="hl">crecimiento</span> sostenido
        </h2>
      </div>
      <div class="reveal-right">
        <p class="services-desc">
          Ofrecemos acompañamiento estratégico adaptado a la madurez de tu empresa. ¿Buscas poner
          orden o una solución de alta especialización para tu industria? Lo hacemos posible a
          través de una metodología frontal, ética y enfocada en resultados.
        </p>
      </div>
    </div>
    <div class="services-grid">
      {services.map((s, i) => (
        <div class={`service-card reveal d${i + 1}`}>
          <div class="service-card-overlay"></div>
          <div class="service-card-body">
            <div class="service-header-row">
              <div class="service-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <h3 class="service-name">{s.name}</h3>
            </div>
            <div class="service-desc">{s.desc}</div>
            <span class="consultant-note">{s.note}</span>
            <a href="/#contacto" class="service-link">Saber más →</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto" id="manifiesto">
    <div class="manifesto-glow"></div>
    <div class="manifesto-glow2"></div>
    <div class="manifesto-inner">
      <div class="manifesto-left reveal-left">
        <div class="manifesto-label">Nuestro Manifiesto</div>
        <h2 class="manifesto-opener">
          No somos auditores.<br />Somos
          <span class="accent">arquitectos del orden.</span>
        </h2>
      </div>
      <div class="manifesto-right">
        <p class="m-paragraph reveal d1">
          En un mundo impulsado por la competencia y los beneficios a corto plazo, es crucial
          recordar que existe una senda más gratificante y sostenible. El camino del orden, de la
          ética, de la innovación y el sentido de equipo.
        </p>
        <p class="m-paragraph reveal d2">
          Hacer las cosas bien requiere paciencia, trabajo extra. Muchas veces significa detenerse
          para mirar hacia adentro. Romper el suelo para levantar nuevos cimientos. Hacer las cosas
          bien casi siempre incomoda, pero sabemos que
          <strong>el orden es el génesis del crecimiento sostenido.</strong>
        </p>
        <div class="m-highlight-block reveal d3">
          <p>
            En Strategio nos comprometemos a allanar el terreno para una nueva generación de
            empresarios que sueñen transformar la cultura empresarial:
            <strong>por más empresarios que establezcan cimientos sólidos sobre los cuales construir
            negocios prósperos que enriquezcan a la sociedad. Por más empresas de alto valor.</strong>
          </p>
        </div>
        <div class="m-closing-block reveal d4">
          <div class="m-closing-text">
            Hay un mejor camino.<br /><span class="accent">Transitémoslo juntos.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POR QUÉ -->
  <section class="porque" id="porque">
    <div class="porque-header">
      <div class="porque-badge reveal"><span class="porque-badge-dot"></span>Strategio como aliado</div>
      <h2 class="porque-title reveal">¿Por qué Strategio?</h2>
      <p class="porque-intro reveal">
        Transformamos la información en resultados medibles. Traducimos indicadores técnicos en
        <strong>decisiones de negocio</strong>, asegurando que cada reporte sea una hoja de ruta
        ética y precisa para alcanzar tus objetivos de rentabilidad.
      </p>
    </div>

    <div class="porque-cross">
      <div class="porque-card tl reveal d1">
        <div class="porque-card-header">
          <div class="porque-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <div class="porque-card-title">Análisis con rigor profesional</div>
        </div>
        <div class="porque-card-desc">Aportamos la visión estratégica de expertos en finanzas corporativas. No solo visualizas resultados; entiendes el porqué de tus números para fortalecer tu patrimonio.</div>
      </div>

      <div></div>

      <div class="porque-card tr reveal d2">
        <div class="porque-card-header">
          <div class="porque-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="porque-card-title">Información sin sesgos</div>
        </div>
        <div class="porque-card-desc">La verdad de los datos es nuestro norte. Implementamos controles que aseguran la transparencia absoluta, eliminando el caos y devolviéndote el mando de tu organización.</div>
      </div>

      <div></div>

      <div class="porque-center">
        <div class="porque-center-glow"></div>
        <div class="porque-center-glow2"></div>
        <div class="porque-center-ring"></div>
        <div class="porque-center-ring2"></div>
        <div class="porque-center-btn">
          <svg width="52" height="52" viewBox="0 0 116 116" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 14.0,38.0 Q 10,38 12.8,35.2 L 35.2,12.8 Q 38,10 38.0,14.0 L 38.0,34.0 Q 38,38 34.0,38.0 Z" fill="white"/>
            <rect x="44" y="10" width="28" height="28" rx="3.5" fill="white"/>
            <path d="M 78.0,14.0 Q 78,10 80.8,12.8 L 103.2,35.2 Q 106,38 102.0,38.0 L 82.0,38.0 Q 78,38 78.0,34.0 Z" fill="white"/>
            <path d="M 12.8,46.8 Q 10,44 14.0,44.0 L 34.0,44.0 Q 38,44 38.0,48.0 L 38.0,68.0 Q 38,72 35.2,69.2 Z" fill="white"/>
            <path d="M 78.0,48.0 Q 78,44 80.8,46.8 L 103.2,69.2 Q 106,72 102.0,72.0 L 82.0,72.0 Q 78,72 78.0,68.0 Z" fill="white"/>
            <path d="M 12.8,80.8 Q 10,78 14.0,78.0 L 34.0,78.0 Q 38,78 38.0,82.0 L 38.0,102.0 Q 38,106 35.2,103.2 Z" fill="white"/>
            <rect x="44" y="78" width="28" height="28" rx="3.5" fill="white"/>
            <path d="M 78.0,82.0 Q 78,78 82.0,78.0 L 102.0,78.0 Q 106,78 103.2,80.8 L 80.8,103.2 Q 78,106 78.0,102.0 Z" fill="white"/>
          </svg>
        </div>
      </div>

      <div></div>

      <div class="porque-card bl reveal d3">
        <div class="porque-card-header">
          <div class="porque-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <div class="porque-card-title">Estructuras personalizadas</div>
        </div>
        <div class="porque-card-desc">Olvídate de las plantillas genéricas. Diseñamos modelos de gestión que se adaptan a la complejidad de tu industria, garantizando un crecimiento ordenado y sostenible.</div>
      </div>

      <div></div>

      <div class="porque-card br reveal d4">
        <div class="porque-card-header">
          <div class="porque-card-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="porque-card-title">Aliado para tu crecimiento</div>
        </div>
        <div class="porque-card-desc">Caminamos junto a tu organización en la implementación de estrategias que transforman el caos en orden, convirtiendo tu información en una ventaja competitiva.</div>
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  {posts.length > 0 && (
    <section class="blog-preview">
      <div class="blog-preview-inner">
        <div class="blog-preview-header">
          <div class="reveal-left">
            <span class="section-tag">Insights</span>
            <h2 class="blog-preview-title">Perspectiva de alto nivel</h2>
          </div>
          <a href="/blog" class="btn-ghost reveal-right">Ver todos →</a>
        </div>
        <div class="blog-grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.id}`} class={`blog-card reveal d${i + 1}`}>
              <div class="blog-card-top">
                <span class="blog-cat">{post.data.category}</span>
                <span class="blog-read">{post.data.readTime} min</span>
              </div>
              <h3 class="blog-card-title">{post.data.title}</h3>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-foot">
                <span>{formatDate(post.data.date)}</span>
                <span class="blog-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA / CONTACTO -->
  <section class="cta-section" id="contacto">
    <div class="cta-glow"></div>
    <div class="cta-inner">
      <div class="cta-badge reveal"><span class="cta-badge-dot"></span>Inmersión inicial</div>
      <h2 class="cta-title reveal">
        La primera sesión es <span class="accent">gratuita.</span>
        <span class="cta-script">empieza con una conversación</span>
      </h2>
      <p class="cta-subtitle reveal d1">
        No ofrecemos diagnósticos genéricos. Realizamos una inmersión inicial de 60 minutos en tu
        negocio y estructura para identificar puntos de fuga de valor. Una conversación define si
        podemos ir juntos por <strong>un mejor camino.</strong>
      </p>
      <form class="cta-form reveal d3" id="contactoForm">
        <div class="form-row">
          <input type="text" name="nombre" class="form-input" placeholder="Nombre *" required />
          <input type="text" name="empresa" class="form-input" placeholder="Empresa" />
        </div>
        <div class="form-row">
          <input type="email" name="correo" class="form-input" placeholder="Correo electrónico *" required />
          <input type="text" name="facturacion" class="form-input" placeholder="Facturación anual aprox." />
        </div>
        <textarea name="mensaje" class="form-input" rows="3" placeholder="¿Cuál es el principal problema que quieres resolver? *" required></textarea>
        <button type="submit" class="btn-submit" id="btnSubmit">Solicitar inmersión inicial →</button>
        <div id="formMsg" class="form-msg"></div>
      </form>
      <div class="contact-divider reveal d4"><span>o si prefieres</span></div>
      <a href="https://wa.me/51940203519?text=Hola%20Strategio%2C%20me%20gustar%C3%ADa%20agendar%20una%20consulta" target="_blank" rel="noopener" class="btn-whatsapp reveal d4">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        Escribirnos por WhatsApp
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 160px 60px 100px;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 52%, transparent 20%, rgba(13, 12, 20, 0.45) 65%, var(--black) 100%);
    pointer-events: none;
    z-index: 2;
  }
  .hero-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1200px;
    height: 800px;
    background: radial-gradient(ellipse at 50% 55%, rgba(107, 53, 232, 0.12) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
  }
  .hero-vp-light {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 180px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.18) 0%, rgba(140, 90, 255, 0.12) 30%, transparent 65%);
    filter: blur(10px);
    pointer-events: none;
    z-index: 1;
  }
  .hero-vp-ground {
    position: absolute;
    top: 62%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse at 50% 0%, rgba(160, 110, 255, 0.18) 0%, rgba(107, 53, 232, 0.08) 30%, transparent 70%);
    pointer-events: none;
    z-index: 1;
    filter: blur(4px);
  }
  .hero-badge,
  .hero-title,
  .hero-desc,
  .hero-actions { position: relative; z-index: 3; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(107, 53, 232, 0.12);
    border: 1px solid var(--purple-light);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--purple-light);
    margin-bottom: 22px;
    animation: fadeUp 0.7s ease both;
  }
  .hero-badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--purple-light);
    box-shadow: 0 0 8px var(--purple-light);
    animation: pulse 2s infinite;
  }
  .hero-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(38px, 5.5vw, 72px);
    line-height: 1;
    color: var(--white);
    letter-spacing: -0.03em;
    animation: fadeUp 0.7s 0.1s ease both;
  }
  .hero-title .accent { color: var(--purple-light); }
  .hero-title .script-accent {
    font-family: "Shadows Into Light", cursive;
    font-weight: 400;
    font-size: 1.1em;
    color: var(--white);
    letter-spacing: 0.01em;
  }
  .hero-desc {
    max-width: 520px;
    margin: 22px auto 0;
    font-size: 15px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 300;
    animation: fadeUp 0.7s 0.2s ease both;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 36px;
    animation: fadeUp 0.7s 0.3s ease both;
  }

  /* ── STATS ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border);
  }
  .stat-item {
    padding: 52px 40px;
    border-right: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .stat-item:last-child { border-right: none; }
  .stat-item::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--purple), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s;
  }
  .stat-item:hover::after { transform: scaleX(1); }
  .stat-number {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: 60px;
    line-height: 1;
    color: var(--white);
    letter-spacing: -0.03em;
  }
  .stat-number span { color: var(--purple-light); }
  .stat-label { font-size: 13px; color: rgba(255, 255, 255, 0.38); margin-top: 8px; line-height: 1.5; }

  /* ── PROBLEMA ── */
  .problema {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 72vh;
    border-bottom: 1px solid var(--border);
  }
  .problema-left {
    padding: 100px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .problema-left::before {
    content: "";
    position: absolute;
    bottom: -120px;
    left: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(107, 53, 232, 0.1), transparent 70%);
  }
  .problema-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3.2vw, 48px);
    line-height: 1.05;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .problema-title .script-inline {
    font-family: "Shadows Into Light", cursive;
    font-size: 1.15em;
    font-weight: 400;
    color: var(--white);
  }
  .underline-accent { position: relative; display: inline-block; }
  .underline-accent svg { display: block; width: 100%; overflow: visible; margin-top: 2px; }
  .problema-right {
    padding: 100px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }
  .problema-intro {
    font-size: 16px;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
  }
  .problema-intro strong { color: var(--white); font-weight: 600; }
  .sintoma-grid { display: flex; flex-direction: column; gap: 16px; margin-top: 12px; }
  .sintoma {
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    transition: border-color 0.3s;
  }
  .sintoma:hover { border-color: rgba(107, 53, 232, 0.45); }
  .sintoma-icon { flex-shrink: 0; margin-top: 3px; }
  .sintoma-desc { font-size: 15px; color: rgba(255, 255, 255, 0.62); line-height: 1.75; font-weight: 300; }
  .sintoma-desc strong { color: var(--white); font-weight: 600; }

  /* ── SERVICIOS ── */
  .services {
    padding: 120px 60px;
    border-bottom: 1px solid var(--border);
    background: var(--black);
    position: relative;
    overflow: hidden;
  }
  .services-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    margin-bottom: 72px;
    gap: 60px;
  }
  .services-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--white);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--white);
    border-radius: 20px;
    padding: 6px 14px;
    margin-bottom: 24px;
  }
  .services-eyebrow-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--orange); }
  .services-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(26px, 2.8vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
  }
  .services-title .hl { color: var(--purple-light); }
  .services-desc {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 300;
    max-width: 380px;
    margin-top: 56px;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: stretch;
  }
  .service-card {
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    min-height: 460px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(160deg, #1a1733 0%, #100e1f 100%);
    transition: transform 0.35s, box-shadow 0.35s;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    text-decoration: none;
  }
  .service-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55); }
  .service-card-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 70% 15%, rgba(107, 53, 232, 0.3), transparent 55%),
      linear-gradient(to top, rgba(10, 9, 20, 0.97) 35%, rgba(10, 9, 20, 0.4) 70%, rgba(10, 9, 20, 0.1) 100%);
  }
  .service-card-body {
    position: relative;
    z-index: 2;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .service-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .service-header-row { display: flex; align-items: center; gap: 14px; }
  .service-name {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .service-desc { font-size: 14px; line-height: 1.7; color: rgba(255, 255, 255, 0.62); font-weight: 300; }
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border-radius: 100px;
    border: 1px solid rgba(107, 53, 232, 0.5);
    background: rgba(107, 53, 232, 0.12);
    color: var(--purple-light);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    width: fit-content;
    transition: background 0.2s, border-color 0.2s;
    margin-top: 4px;
  }
  .service-link:hover { background: rgba(107, 53, 232, 0.25); border-color: var(--purple-light); }
  .consultant-note {
    font-family: "Shadows Into Light", cursive;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
    padding-top: 10px;
    border-top: 1px dashed rgba(107, 53, 232, 0.25);
    transform: rotate(-0.6deg);
    display: block;
  }

  /* ── MANIFESTO ── */
  .manifesto {
    padding: 160px 60px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, var(--black) 0%, #0e0c1e 50%, var(--black) 100%);
  }
  .manifesto-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(107, 53, 232, 0.1), transparent 68%);
    pointer-events: none;
  }
  .manifesto-glow2 {
    position: absolute;
    right: -200px;
    top: 20%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(107, 53, 232, 0.07), transparent 70%);
    pointer-events: none;
  }
  .manifesto-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .manifesto-left { position: sticky; top: 120px; }
  .manifesto-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--purple-light);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .manifesto-label::before,
  .manifesto-label::after {
    content: "";
    flex: 1;
    max-width: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--purple-light));
  }
  .manifesto-label::after { background: linear-gradient(90deg, var(--purple-light), transparent); }
  .manifesto-opener {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .manifesto-opener .accent { color: var(--purple-light); }
  .manifesto-right { display: flex; flex-direction: column; padding-top: 8px; }
  .m-paragraph {
    font-size: 16px;
    line-height: 1.9;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.52);
    padding: 28px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  .m-paragraph:first-child { padding-top: 0; }
  .m-paragraph strong { color: rgba(255, 255, 255, 0.85); font-weight: 500; }
  .m-highlight-block {
    margin-top: 36px;
    padding: 36px 40px;
    background: rgba(107, 53, 232, 0.07);
    border: 1px solid rgba(107, 53, 232, 0.2);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
  }
  .m-highlight-block::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light), transparent);
  }
  .m-highlight-block p { font-size: 16px; line-height: 1.9; font-weight: 300; color: rgba(255, 255, 255, 0.72); }
  .m-highlight-block strong { color: var(--white); font-weight: 600; }
  .m-closing-block { margin-top: 40px; }
  .m-closing-text {
    font-family: "Archivo", sans-serif;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.1;
    color: var(--white);
    letter-spacing: 0.02em;
  }
  .m-closing-text .accent { color: var(--purple-light); }

  /* ── POR QUÉ ── */
  .porque {
    padding: 120px 60px;
    border-bottom: 1px solid var(--border);
    background: var(--deep);
    position: relative;
    overflow: hidden;
  }
  .porque-header { text-align: center; margin-bottom: 72px; }
  .porque-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--white);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--white);
    border-radius: 20px;
    padding: 6px 14px;
    margin-bottom: 24px;
  }
  .porque-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--orange); }
  .porque-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 20px;
  }
  .porque-intro {
    font-size: 16px;
    line-height: 1.8;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.52);
    max-width: 700px;
    margin: 0 auto;
  }
  .porque-intro strong { color: var(--white); font-weight: 600; }
  .porque-cross {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 200px 1fr;
    grid-template-rows: 1fr 200px 1fr;
    align-items: center;
    min-height: 620px;
  }
  .porque-card {
    background: linear-gradient(135deg, rgba(107, 53, 232, 0.22) 0%, rgba(107, 53, 232, 0.06) 100%);
    border: 1px solid rgba(107, 53, 232, 0.25);
    border-radius: 16px;
    padding: 28px 30px;
    position: relative;
    z-index: 2;
    transition: border-color 0.3s, transform 0.25s, box-shadow 0.3s;
  }
  .porque-card:hover {
    border-color: rgba(107, 53, 232, 0.55);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(107, 53, 232, 0.2);
  }
  .porque-card-header { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
  .porque-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--purple);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .porque-card-title { font-size: 16px; font-weight: 700; color: var(--white); line-height: 1.3; }
  .porque-card-desc { font-size: 13px; color: rgba(255, 255, 255, 0.5); line-height: 1.75; font-weight: 300; }
  .porque-card.tl { grid-column: 1; grid-row: 1; }
  .porque-card.tr { grid-column: 3; grid-row: 1; }
  .porque-card.bl { grid-column: 1; grid-row: 3; }
  .porque-card.br { grid-column: 3; grid-row: 3; }
  .porque-center {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 3;
  }
  .porque-center-glow {
    position: absolute;
    width: 600px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(107, 53, 232, 0.32) 0%, rgba(107, 53, 232, 0.1) 45%, transparent 70%);
    pointer-events: none;
  }
  .porque-center-glow2 {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(120, 60, 240, 0.3) 0%, transparent 70%);
    pointer-events: none;
  }
  .porque-center-ring { position: absolute; width: 200px; height: 200px; border-radius: 50%; border: 1px solid rgba(160, 120, 255, 0.18); }
  .porque-center-ring2 { position: absolute; width: 145px; height: 145px; border-radius: 50%; border: 1px dashed rgba(160, 120, 255, 0.28); }
  .porque-center-btn {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #6b35e8;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    box-shadow:
      0 0 0 2px rgba(255, 255, 255, 0.08),
      0 0 10px rgba(255, 255, 255, 0.35),
      0 0 24px rgba(180, 130, 255, 0.45),
      0 0 55px rgba(107, 53, 232, 0.4);
  }
  .porque-center-btn svg { filter: drop-shadow(0 0 3px rgba(255, 255, 255, 0.7)); }

  /* ── BLOG PREVIEW ── */
  .blog-preview { padding: 120px 60px; border-bottom: 1px solid var(--border); background: var(--black); }
  .blog-preview-inner { max-width: 1200px; margin: 0 auto; }
  .blog-preview-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .blog-preview-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-top: 18px;
  }
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .blog-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 26px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s, transform 0.25s;
  }
  .blog-card:hover { border-color: rgba(107, 53, 232, 0.45); transform: translateY(-4px); }
  .blog-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .blog-cat {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--purple-light);
    border: 1px solid rgba(139, 92, 246, 0.4);
    border-radius: 100px;
    padding: 4px 10px;
  }
  .blog-read { font-size: 12px; color: rgba(255, 255, 255, 0.35); }
  .blog-card-title {
    font-family: "Archivo", sans-serif;
    font-weight: 700;
    font-size: 19px;
    line-height: 1.25;
    color: var(--white);
    margin-bottom: 12px;
  }
  .blog-card-desc { font-size: 13px; line-height: 1.7; color: rgba(255, 255, 255, 0.45); font-weight: 300; flex: 1; }
  .blog-card-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
  }
  .blog-arrow { color: var(--purple-light); font-weight: 700; transition: transform 0.2s; }
  .blog-card:hover .blog-arrow { transform: translateX(4px); }

  /* ── CTA ── */
  .cta-section { padding: 140px 60px; text-align: center; position: relative; overflow: hidden; }
  .cta-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(107, 53, 232, 0.18), transparent 65%);
    pointer-events: none;
  }
  .cta-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--white);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--white);
    border-radius: 20px;
    padding: 6px 14px;
    margin-bottom: 24px;
  }
  .cta-badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--orange); flex-shrink: 0; }
  .cta-title {
    font-family: "Archivo", sans-serif;
    font-weight: 900;
    font-size: clamp(26px, 2.8vw, 42px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 24px;
  }
  .cta-title .accent { color: var(--purple-light); }
  .cta-script {
    font-family: "Shadows Into Light", cursive;
    font-size: 0.58em;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.32);
    display: block;
    line-height: 1.3;
    margin-top: 6px;
  }
  .cta-subtitle { font-size: 16px; color: rgba(255, 255, 255, 0.45); font-weight: 300; line-height: 1.75; margin-bottom: 40px; }
  .cta-subtitle strong { color: var(--white); font-weight: 600; }
  .cta-form { display: flex; flex-direction: column; gap: 12px; text-align: left; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .form-input {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--white);
    padding: 14px 18px;
    font-family: "Archivo", sans-serif;
    font-size: 14px;
    width: 100%;
    transition: border-color 0.2s;
    resize: none;
  }
  .form-input::placeholder { color: rgba(255, 255, 255, 0.22); }
  .form-input:focus { outline: none; border-color: var(--purple); }
  .btn-submit {
    background: var(--purple);
    color: var(--white);
    padding: 16px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    width: 100%;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-submit:hover { background: var(--purple-light); transform: translateY(-1px); }
  .form-msg { display: none; padding: 14px 18px; border-radius: 10px; font-size: 14px; font-weight: 600; text-align: center; margin-top: 4px; }
  .form-msg.show { display: block; background: rgba(107, 53, 232, 0.12); color: var(--purple-light); }
  .contact-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
    color: rgba(255, 255, 255, 0.2);
    font-size: 12px;
    letter-spacing: 0.1em;
  }
  .contact-divider::before,
  .contact-divider::after { content: ""; flex: 1; height: 1px; background: rgba(255, 255, 255, 0.08); }
  .btn-whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px;
    background: rgba(37, 211, 102, 0.1);
    border: 1px solid rgba(37, 211, 102, 0.3);
    border-radius: 100px;
    color: #25d366;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .btn-whatsapp:hover { background: rgba(37, 211, 102, 0.18); border-color: rgba(37, 211, 102, 0.6); transform: translateY(-1px); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero { padding: 120px 24px 60px; }
    .hero-actions { flex-direction: column; align-items: stretch; }
    .btn-primary, .btn-ghost { justify-content: center; padding: 14px 22px; }
    .stats { grid-template-columns: 1fr 1fr; }
    .stat-item { padding: 36px 24px; border-bottom: 1px solid var(--border); }
    .stat-item:nth-child(2) { border-right: none; }
