<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const msg = document.getElementById('formMsg');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.textContent = 'Enviando...';
    btn.disabled = true;
    setTimeout(() => {
      msg.textContent = '✓ Mensaje recibido. Le contactaremos en menos de 24 horas.';
      msg.classList.remove('hidden');
      form.reset();
      btn.textContent = 'Enviar mensaje';
      btn.disabled = false;
    }, 1200);
  });

  // Purple hover on blog cards
  document.querySelectorAll('[data-hover-purple]').forEach(el => {
    el.closest('a').addEventListener('mouseenter', () => (el as HTMLElement).style.color = '#4D0FC1');
    el.closest('a').addEventListener('mouseleave', () => (el as HTMLElement).style.color = '#F8F8FF');
  });
</script>
